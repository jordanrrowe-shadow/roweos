rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /access_keys/{keyId} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      allow create, delete: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      allow update: if request.auth != null && (
        request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93' ||
        (resource.data.usedBy == null && request.resource.data.usedBy == request.auth.uid)
      );
    }
    match /brand_configs/{configId} {
      allow get: if request.auth != null;
      allow list, create, delete: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      allow update: if request.auth != null && (
        request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93' ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']))
      );
    }
    match /api_key_pool/{keyId} {
      allow read, create, delete: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      allow update: if request.auth != null;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      }
    }
    match /roweos_users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      }
    }
    // v28.0: Sync v4 namespace (parent doc + all subcollections)
    match /roweos_v4/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93');
      }
    }
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      match /screenshots/{screenshotId} {
        allow create: if request.auth != null;
        allow read, delete: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      }
    }
    // v22.4: Newsletter subscribers — admin read only (server writes via service account)
    match /newsletter_subscribers/{docId} {
      allow read, delete: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
    }
    // v22.4: Admin notifications — admin read/update (server writes via service account)
    match /admin_notifications/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
    }
    // v30.1: Email log — admin read/write (client logs sent emails, server logs welcome emails)
    match /email_log/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
    }
    // v30.1: Onboarding responses — admin read, server writes via email-response endpoint
    match /onboarding_responses/{userId} {
      allow read: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      match /responses/{responseId} {
        allow read: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
      }
    }
    // v30.1: Email settings — admin read/write
    match /email_settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
    }
    // v30.1: Signups — admin read (server writes via service account)
    match /signups/{docId} {
      allow read: if request.auth != null && request.auth.uid == 'cG3DEoz2Kkd9i1cSPLOFqPfUYB93';
    }
  }
}
